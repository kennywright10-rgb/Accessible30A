# =============================================================================
# Accessible 30A — Environment Variables
# Copy to .env.local and fill in your values
# =============================================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe (Phase 1: affiliate tracking, Phase 2: direct bookings)
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Google Maps (for property distance calculations + map embeds)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-maps-key

# Site
NEXT_PUBLIC_SITE_URL=https://accessible30a.com
NEXT_PUBLIC_SITE_NAME=Accessible 30A

# Analytics (optional)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# CJ Affiliate (VRBO affiliate program)
CJ_AFFILIATE_PUBLISHER_ID=
CJ_AFFILIATE_WEBSITE_ID=
